@model IEnumerable<UMS.Domain.Entities.Course>

@{
    ViewData["Title"] = "Courses";
}

<div class="container mt-4">
    <h2>Courses List</h2>
    <p>All available courses in the university</p>

    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Course Code</th>
                <th>Course Name</th>
                <th>Credits</th>
                <th>Instructor</th>
                <th>Enrolled Students</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var course in Model)
            {
                <tr>
                    <td>@course.Id</td>
                    <td>@course.CourseCode</td>
                    <td>@course.CourseName</td>
                    <td>@course.Credits</td>
                    <td>@course.Instructor</td>
                    <td>@course.Enrollments.Count</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@course.Id" class="btn btn-sm btn-info">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
