@model UMS.Domain.Entities.Course

@{
    ViewData["Title"] = "Course Details";
}

<div class="container mt-4">
    <h2>Course Details</h2>
    
    <div class="card">
        <div class="card-header">
            <h4>@Model.CourseName (@Model.CourseCode)</h4>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Course ID</dt>
                <dd class="col-sm-9">@Model.Id</dd>

                <dt class="col-sm-3">Description</dt>
                <dd class="col-sm-9">@Model.Description</dd>

                <dt class="col-sm-3">Credits</dt>
                <dd class="col-sm-9">@Model.Credits</dd>

                <dt class="col-sm-3">Instructor</dt>
                <dd class="col-sm-9">@Model.Instructor</dd>
            </dl>

            <h5 class="mt-4">Enrolled Students</h5>
            @if (Model.Enrollments.Any())
            {
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Student Name</th>
                            <th>Email</th>
                            <th>Enrollment Date</th>
                            <th>Grade</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var enrollment in Model.Enrollments)
                        {
                            <tr>
                                <td>@enrollment.Student.FirstName @enrollment.Student.LastName</td>
                                <td>@enrollment.Student.Email</td>
                                <td>@enrollment.EnrollmentDate.ToString("MM/dd/yyyy")</td>
                                <td>@(string.IsNullOrEmpty(enrollment.Grade) ? "N/A" : enrollment.Grade)</td>
                                <td>@enrollment.Status</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p>No students enrolled yet.</p>
            }
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</div>
