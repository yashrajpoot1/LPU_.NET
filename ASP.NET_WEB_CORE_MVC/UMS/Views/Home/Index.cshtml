@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome to University Management System</h1>
    <p class="lead">Manage students, courses, and enrollments efficiently</p>
</div>

<div class="container mt-5">
    <div class="row">
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">Students</h5>
                    <p class="card-text">View and manage student information</p>
                    <a asp-controller="Students" asp-action="Index" class="btn btn-primary">View Students</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">Courses</h5>
                    <p class="card-text">Browse available courses and instructors</p>
                    <a asp-controller="Courses" asp-action="Index" class="btn btn-success">View Courses</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">Enrollments</h5>
                    <p class="card-text">Track student course enrollments</p>
                    <a asp-controller="Enrollments" asp-action="Index" class="btn btn-info">View Enrollments</a>
                </div>
            </div>
        </div>
    </div>
</div>
