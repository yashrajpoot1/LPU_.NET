@model List<Ecommerce_Inventory.Models.Product>

@{
    ViewData["Title"] = string.IsNullOrEmpty(ViewBag.SelectedGender) ? "All Products" : $"{ViewBag.SelectedGender}'s Clothing";
}

<div class="container">
    <h1 class="mb-4">@ViewData["Title"]</h1>
    
    <div class="row">
        @foreach (var product in Model)
        {
            <div class="col-md-3 mb-4">
                <div class="card h-100">
                    <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name" style="height: 250px; object-fit: cover;">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@product.Name</h5>
                        <p class="card-text text-muted">@product.Description</p>
                        <p class="card-text"><strong>$@product.Price.ToString("F2")</strong></p>
                        <div class="mt-auto">
                            <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" class="btn btn-primary btn-sm w-100">View Details</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
