@using Flight_Application.Models

@{
    ViewData["Title"] = "Search Results";
    var searchType = ViewBag.SearchType as string;
    var searchCriteria = ViewBag.SearchCriteria as string;
}

<div class="container mt-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Flight">Search</a></li>
            <li class="breadcrumb-item active" aria-current="page">Results</li>
        </ol>
    </nav>

    <div class="card shadow">
        <div class="card-header bg-info text-white">
            <h3 class="mb-0">
                <i class="fas fa-list"></i> Search Results
            </h3>
            @if (!string.IsNullOrEmpty(searchCriteria))
            {
                <small>@searchCriteria</small>
            }
        </div>
        <div class="card-body">
            @if (Model == null || (Model is IEnumerable<object> enumerable && !enumerable.Any()))
            {
                <div class="alert alert-warning text-center" role="alert">
                    <i class="fas fa-exclamation-triangle fa-3x mb-3"></i>
                    <h4>No Results Found</h4>
                    <p>Sorry, we couldn't find any flights matching your search criteria.</p>
                    <p>Please try different source or destination locations.</p>
                </div>
            }
            else if (searchType == "Flights" && Model is IEnumerable<FlightResult> flightResults)
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Flight ID</th>
                                <th>Flight Name</th>
                                <th>Flight Type</th>
                                <th>Source</th>
                                <th>Destination</th>
                                <th class="text-end">Total Cost (₹)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var flight in flightResults)
                            {
                                <tr>
                                    <td>@flight.FlightId</td>
                                    <td><strong>@flight.FlightName</strong></td>
                                    <td>
                                        <span class="badge @(flight.FlightType == "Domestic" ? "bg-success" : "bg-primary")">
                                            @flight.FlightType
                                        </span>
                                    </td>
                                    <td>@flight.Source</td>
                                    <td>@flight.Destination</td>
                                    <td class="text-end"><strong>₹@flight.TotalCost.ToString("N2")</strong></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="alert alert-info mt-3">
                    <i class="fas fa-info-circle"></i> Found <strong>@flightResults.Count()</strong> flight(s) matching your criteria.
                </div>
            }
            else if (searchType == "FlightsWithHotels" && Model is IEnumerable<FlightHotelResult> packageResults)
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Flight ID</th>
                                <th>Flight Name</th>
                                <th>Source</th>
                                <th>Destination</th>
                                <th>Hotel Name</th>
                                <th class="text-end">Total Cost (₹)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var package in packageResults)
                            {
                                <tr>
                                    <td>@package.FlightId</td>
                                    <td><strong>@package.FlightName</strong></td>
                                    <td>@package.Source</td>
                                    <td>@package.Destination</td>
                                    <td>
                                        <i class="fas fa-hotel text-warning"></i> @package.HotelName
                                    </td>
                                    <td class="text-end"><strong>₹@package.TotalCost.ToString("N2")</strong></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="alert alert-info mt-3">
                    <i class="fas fa-info-circle"></i> Found <strong>@packageResults.Count()</strong> package(s) matching your criteria.
                    <br><small>Package includes flight for all persons + hotel for 1 day</small>
                </div>
            }

            <div class="mt-4">
                <a asp-action="Index" asp-controller="Flight" class="btn btn-primary">
                    <i class="fas fa-arrow-left"></i> Back to Search
                </a>
            </div>
        </div>
    </div>
</div>
