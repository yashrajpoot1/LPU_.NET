@model IEnumerable<StudentPortal.Models.Course>

@{
    ViewData["Title"] = "Courses";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-book-fill"></i> Courses List</h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Course
        </a>
    </div>

    @if (Model.Any())
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>@Html.DisplayNameFor(model => model.Title)</th>
                                <th>@Html.DisplayNameFor(model => model.DurationDays)</th>
                                <th>@Html.DisplayNameFor(model => model.Fee)</th>
                                <th>@Html.DisplayNameFor(model => model.Level)</th>
                                <th>@Html.DisplayNameFor(model => model.IsActive)</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@Html.DisplayFor(modelItem => item.Title)</td>
                                    <td>
                                        <i class="bi bi-clock"></i> @item.DurationDays days
                                    </td>
                                    <td>
                                        <i class="bi bi-currency-dollar"></i> @item.Fee.ToString("N2")
                                    </td>
                                    <td>
                                        @if (item.Level == "Beginner")
                                        {
                                            <span class="badge bg-info">@item.Level</span>
                                        }
                                        else if (item.Level == "Intermediate")
                                        {
                                            <span class="badge bg-warning text-dark">@item.Level</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">@item.Level</span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success"><i class="bi bi-check-circle"></i> Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary"><i class="bi bi-x-circle"></i> Inactive</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-action="Details" asp-route-id="@item.CourseId" class="btn btn-info" title="Details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.CourseId" class="btn btn-warning" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.CourseId" class="btn btn-danger" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center" role="alert">
            <i class="bi bi-info-circle fs-3"></i>
            <p class="mb-0 mt-2">No courses found. Click "Add New Course" to get started.</p>
        </div>
    }
</div>
