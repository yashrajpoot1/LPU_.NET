@model IEnumerable<StudentPortal.Models.Student>

@{
    ViewData["Title"] = "Students";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-people-fill"></i> Students List</h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Student
        </a>
    </div>

    @if (Model.Any())
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>@Html.DisplayNameFor(model => model.FullName)</th>
                                <th>@Html.DisplayNameFor(model => model.Email)</th>
                                <th>@Html.DisplayNameFor(model => model.Phone)</th>
                                <th>@Html.DisplayNameFor(model => model.Status)</th>
                                <th>@Html.DisplayNameFor(model => model.JoinDate)</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@Html.DisplayFor(modelItem => item.FullName)</td>
                                    <td>
                                        <i class="bi bi-envelope"></i> @Html.DisplayFor(modelItem => item.Email)
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.Phone))
                                        {
                                            <i class="bi bi-telephone"></i> @Html.DisplayFor(modelItem => item.Phone)
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.Status == "Active")
                                        {
                                            <span class="badge bg-success">@item.Status</span>
                                        }
                                        else if (item.Status == "Inactive")
                                        {
                                            <span class="badge bg-secondary">@item.Status</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">@item.Status</span>
                                        }
                                    </td>
                                    <td>
                                        <i class="bi bi-calendar-event"></i> @item.JoinDate.ToString("MMM dd, yyyy")
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-action="Details" asp-route-id="@item.StudentId" class="btn btn-info" title="Details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.StudentId" class="btn btn-warning" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.StudentId" class="btn btn-danger" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center" role="alert">
            <i class="bi bi-info-circle fs-3"></i>
            <p class="mb-0 mt-2">No students found. Click "Add New Student" to get started.</p>
        </div>
    }
</div>
